# Generic Linux bootstrap defaults.
# Override per target in board-specific profiles.

PROFILE_NAME="generic_linux"

# Repo/bootstrap
CANONICAL_WORKSPACE_PATH="$HOME/robotics-fundamentals-lab"
PYTHON_BIN="python3"

# Package/runtime toggles
ENABLE_ROS2="1"
ENABLE_OPENCV="1"
ENABLE_CSI_CAMERA="1"
ENABLE_AI_ACCELERATOR="0"
ENABLE_HMI_STACK="1"

# Interface toggles
ENABLE_I2C="1"
ENABLE_SPI="1"
ENABLE_UART="1"

# Network/host defaults
WIFI_COUNTRY_CODE="US"
HMI_HTTP_PORT="8080"
