# Raspberry Pi Debian-family profile defaults.
# Source this after generic_linux.env to override values.

PROFILE_NAME="rpi_debian"

ENABLE_I2C="1"
ENABLE_SPI="1"
ENABLE_UART="1"
ENABLE_CSI_CAMERA="1"
ENABLE_OPENCV="1"
ENABLE_HMI_STACK="1"

# Adjust depending on distro + ROS2 release compatibility.
ENABLE_ROS2="1"
ROS2_DISTRO="jazzy"

# Optional accelerator integrations can be enabled when hardware is present.
ENABLE_AI_ACCELERATOR="0"

WIFI_COUNTRY_CODE="US"
HMI_HTTP_PORT="8080"
